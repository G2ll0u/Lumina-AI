# Lumina AI - RAG Backend Configuration
# Copy this file to '.env' and fill in your values.

# === PATHS ===
DOCS_PATH = "C:\\Path\\To\\Your\\Documents"
TARGET_FOLDER = "FolderName"

# === LLM MODELS (via Ollama or OpenAI-compatible API) ===
LLM_BASE_URL = "http://localhost:11434"
LLM_API_KEY = ""
LLM_MODEL = "llama3"
CHAT_MODEL = "llama3"
DECOMPOSE_MODEL = "llama3"
HYDE_MODEL = "llama3"
VISION_MODEL = llava

# === EMBEDDING MODEL (local, via sentence-transformers) ===
EMBEDDING_MODEL_NAME = "sentence-transformers/all-MiniLM-L6-v2"

# === RERANKER MODEL ===
# Default: BAAI/bge-reranker-v2-m3 (~1GB download on first run, multilingual)
RERANKER_MODEL = BAAI/bge-reranker-v2-m3

# === SECURITY (authentication) ===
# Leave empty to run in open/dev mode (warning will be printed)
# SECRET_KEY = "change_this_to_a_secure_random_string"

# === TESSERACT OCR ===
# Full path to the tesseract executable
# Windows default: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_PATH = "C:\\Program Files\\Tesseract-OCR\\tesseract.exe"

# === CHROMADB ===
CHROMA_HOST = "localhost"
CHROMA_PORT = "8000"

# === LLM INFERENCE PARAMETERS ===
# num_ctx: context window size (tokens). Increase if your GPU has enough VRAM.
LLM_NUM_CTX = 4096
# num_predict: max tokens to generate per response.
LLM_NUM_PREDICT = 1024
# Tokens to generate for HyDE synthetic documents (short, so fewer tokens needed).
HYDE_NUM_PREDICT = 150
# Vision model sends no layers to GPU by default (runs on CPU). Set to 33+ to use GPU.
VISION_NUM_GPU = 0

# === TIMEOUTS (seconds) ===
LLM_STREAM_TIMEOUT = 600.0
LLM_DECOMPOSE_TIMEOUT = 15.0
LLM_HYDE_TIMEOUT = 20.0
LLM_VISION_TIMEOUT = 120.0

# === RETRIEVAL PARAMETERS ===
# BM25 index is rebuilt from ChromaDB on startup and cached in RAM for BM25_CACHE_TTL seconds.
BM25_CACHE_TTL = 3600
# Max files returned by the filename search step.
SEARCH_MAX_FILES = 10
# Max files deeply inspected per query (top N from SEARCH_MAX_FILES).
SEARCH_MAX_TARGET_FILES = 3
# Chunk quota per source: technical files (schemas, IO lists) vs generic docs (manuals).
SEARCH_TECHNICAL_CHUNK_QUOTA = 5
SEARCH_GENERIC_CHUNK_QUOTA = 1
# Score boost applied to nomenclature/schema chunks after reranking.
RERANKER_NOMENCLATURE_BOOST = 0.1

# === CONTEXT & QUERY ===
# Max characters of RAG context sent to the LLM (larger for quantity questions).
MAX_CONTEXT_QUANTITY = 30000
MAX_CONTEXT_DEFAULT = 15000
# Max web search results to fetch when web search is enabled.
WEB_SEARCH_MAX_RESULTS = 3
# JSON array of keywords that identify "how many" / listing questions.
QUANTITY_KEYWORDS = ["combien", "liste", "nombre", "how many"]
FOOTER_PATTERNS = ["Footer below"]
# === APP ===
APP_TITLE = "Lumina AI - RAG Backend"

# === COMPONENT EXTRACTION AT INGESTION TIME ===
# JSON dict mapping a label to a regex pattern.
# During ingestion, each document is scanned with these patterns.
# A synthetic summary chunk is created per document listing all unique codes found.
# This allows the LLM to answer "how many X are installed?" reliably.
# Leave as {} to disable.
# The (?:\\d{1,2})? prefix is optional: matches both MP1 and 13MP1W formats.
# COMPONENT_EXTRACTION_PATTERNS = {"Pump (MP)": "\\b(?:\\d{1,2})?MP\\d+[A-Z]*\\b", "Motor (M)": "\\b(?:\\d{1,2})?M\\d+[A-Z]*\\b"}
COMPONENT_EXTRACTION_PATTERNS = {}

# Built-in regex filters to remove repetitive footers across pages.
# Useful to avoid polluting small chunks with generic phone numbers or emails.
# FOOTER_PATTERNS = ['r"Tél\\s*:\\s*\\+33[^\\n]*\\n?"', 'r"Fax\\s*:\\s*\\+33[^\\n]*\\n?"']
FOOTER_PATTERNS = []

# === INGESTION FILTERS (optional) ===
# JSON array of words to exclude from filenames during ingestion
EXCLUDED_WORDS = '["words", "to", "exclude"]'
# JSON array of keywords to force hi_res (advanced OCR) on PDFs
HI_RES_KEYWORDS = '["words", "to", "trigger", "hi", "res"]'

# === SYSTEM PROMPT (optional - overrides the default prompt in code) ===
# BASE_SYSTEM_PROMPT = "You are an expert industrial maintenance assistant. Answer accurately and concisely."

# === CRITICAL INSTRUCTIONS (optional - injected at the end of each user message) ===
# CRITICAL_INSTRUCTIONS = "\nIMPORTANT:\n1. Always answer in the user's language.\n2. Use ONLY the provided context."
